# Google Maps (public - safe to expose to browser)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
NEXT_PUBLIC_GOOGLE_MAPS_MAP_ID=

# Google Maps Directions API (server-only - never expose to browser)
NEXT_GOOGLE_DIRECTIONS_API_KEY=

# Enable directions feature (set to "true" to enable origin input + route directions)
NEXT_PUBLIC_DIRECTIONS_ENABLED=false

# AWS Configuration (server-only - never expose to browser)
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# DynamoDB Table Name (server-only - never expose to browser)
NEXT_DYNAMODB_TABLE_NAME=

## 경기도 공공 데이터 포털 API 키 (server-only - never expose to browser)
NEXT_GG_COMMON_DATA_KEY=
